{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...all]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPall": "nxtPall"
      },
      "namedRegex": "^/api/auth/(?<nxtPall>.+?)(?:/)?$"
    },
    {
      "page": "/api/messages/stream/[conversationId]",
      "regex": "^/api/messages/stream/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPconversationId": "nxtPconversationId"
      },
      "namedRegex": "^/api/messages/stream/(?<nxtPconversationId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/messages/[conversationId]",
