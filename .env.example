# ═══════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════

# ─── Database ───
# MongoDB Atlas connection string
DATABASE_URL="mongodb+srv://username:password@cluster.xxxxx.mongodb.net/colocdz?retryWrites=true&w=majority"

# ─── Authentication ───
# Generate a strong random secret (min 32 chars): openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-random-secret-here-minimum-32-characters"
BETTER_AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# ─── OAuth Providers ───
# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (requires HTTPS, https://developers.facebook.com/)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── SMS/Notifications ───
# Twilio (https://www.twilio.com/)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1234567890"

# ─── Firebase (Optional) ───
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ─── Image Storage ───
# Configure your image domain (Cloudinary, AWS S3, etc.)
NEXT_PUBLIC_IMAGE_DOMAIN=""
